# Application secret used for JWT/session signing.
SECRET_KEY=replace-with-a-long-random-secret

# MongoDB connection string; includes default DB and replica-set for local dev.
MONGO_URI=mongodb://mongo:27017/kriegspiel?replicaSet=rs0

# Runtime environment label.
ENVIRONMENT=development

# Structured log level.
LOG_LEVEL=info

# Frontend origin used for CORS.
SITE_ORIGIN=http://localhost:5173

# Local Mongo Express basic auth.
ME_USERNAME=admin
ME_PASSWORD=admin
